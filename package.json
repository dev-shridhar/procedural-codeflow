{
  "name": "codedetective",
  "displayName": "CodeDetective",
  "description": "Instant flowcharts from your Python code. Right-click any function — CodeDetective parses it with tree-sitter, resolves calls across files, and renders an interactive control-flow diagram right inside VS Code.",
  "version": "0.4.4",
  "publisher": "dev-shridhar",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-shridhar/code-detective.git"
  },
  "license": "MIT",
  "icon": "media/icon128.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "keywords": [
    "python",
    "control flow graph",
    "cfg",
    "diagram",
    "flowchart",
    "visualization",
    "code detective"
  ],
  "categories": [
    "Visualization",
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codedetective.showCodeFlow",
        "title": "CodeDetective: Show code flow"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "codedetective.showCodeFlow",
          "when": "editorLangId == python",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.24.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "elkjs": "^0.9.3",
    "roughjs": "^4.6.6",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.22.0"
  }
}
